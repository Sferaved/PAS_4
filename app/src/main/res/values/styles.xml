<resources>

    <style name="Widget.Theme.PAS_4.ActionBar.Fullscreen" parent="Widget.AppCompat.ActionBar">
        <item name="android:background">@color/black_overlay</item>
    </style>

    <style name="Widget.Theme.PAS_3.ButtonBar.Fullscreen" parent="">
        <item name="android:background">@color/black_overlay</item>
        <item name="android:buttonBarStyle">?android:attr/buttonBarStyle</item>
    </style>

    <style name="CircularImageView" parent="">
        <item name="shapeAppearanceOverlay">@style/ShapeAppearanceOverlay.Circular</item>
    </style>

    <style name="ShapeAppearanceOverlay.Circular" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>
    <style name="WidgetWeatherText">
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:shadowColor">#20000000</item>
        <item name="android:shadowDx">1</item>
        <item name="android:shadowDy">1</item>
        <item name="android:shadowRadius">2</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>
</resources>