<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_landing_language_option"
    android:clickable="true"
    android:focusable="true"
    android:gravity="center_vertical"
    android:minHeight="52dp"
    android:orientation="horizontal"
    android:paddingStart="12dp"
    android:paddingTop="10dp"
    android:paddingEnd="12dp"
    android:paddingBottom="10dp">

    <TextView
        android:id="@+id/langOptionBadge"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="@drawable/bg_landing_lang_badge"
        android:fontFamily="@font/medium"
        android:gravity="center"
        android:textColor="@color/zamov"
        android:textSize="13sp"
        tools:text="UA" />

    <TextView
        android:id="@+id/langOptionLabel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_weight="1"
        android:fontFamily="@font/regular"
        android:textColor="@color/uklon_on_surface"
        android:textSize="16sp"
        tools:text="Українська" />

    <ImageView
        android:id="@+id/langOptionCheck"
        android:layout_width="22dp"
        android:layout_height="22dp"
        android:contentDescription="@null"
        android:src="@drawable/ic_check"
        android:visibility="gone"
        app:tint="@color/zamov"
        tools:visibility="visible" />
</LinearLayout>
