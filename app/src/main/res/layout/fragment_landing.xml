<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/uklon_bg"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingTop="20dp"
        android:paddingEnd="16dp"
        android:paddingBottom="28dp">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/landingHeroCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@android:color/transparent"
            app:cardCornerRadius="24dp"
            app:cardElevation="4dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_landing_hero"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:paddingStart="20dp"
                android:paddingTop="24dp"
                android:paddingEnd="20dp"
                android:paddingBottom="24dp">

                <ImageView
                    android:id="@+id/ivLandingLogo"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:contentDescription="@string/nav_header_desc"
                    android:src="@mipmap/ic_launcher_round" />

                <TextView
                    android:id="@+id/tvLandingGreeting"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:fontFamily="@font/medium"
                    android:gravity="center"
                    android:text="@string/landing_greeting"
                    android:textColor="@color/white"
                    android:textSize="24sp" />

                <TextView
                    android:id="@+id/tvLandingSubtitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:fontFamily="@font/regular"
                    android:gravity="center"
                    android:lineSpacingExtra="2dp"
                    android:text="@string/landing_greeting_subtitle_guest"
                    android:textColor="@color/white_70"
                    android:textSize="15sp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLandingQuickOrder"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginBottom="16dp"
            android:fontFamily="@font/medium"
            android:text="@string/landing_quick_order"
            android:textAllCaps="false"
            android:textColor="@color/uklon_on_primary"
            android:textSize="17sp"
            app:backgroundTint="@color/uklon_yellow"
            app:cornerRadius="26dp"
            app:icon="@drawable/ic_shortcut_order"
            app:iconGravity="textStart"
            app:iconPadding="10dp"
            app:iconTint="@color/uklon_on_primary"
            app:rippleColor="@color/uklon_ripple" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/landingLoginCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            app:cardBackgroundColor="@color/uklon_surface"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/uklon_outline"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/medium"
                    android:text="@string/landing_login_title"
                    android:textColor="@color/uklon_on_surface"
                    android:textSize="17sp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:layout_marginBottom="14dp"
                    android:fontFamily="@font/regular"
                    android:lineSpacingExtra="2dp"
                    android:text="@string/landing_login_subtitle"
                    android:textColor="@color/uklon_on_surface_secondary"
                    android:textSize="14sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnLandingLogin"
                    style="@style/Widget.MaterialComponents.Button"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:fontFamily="@font/medium"
                    android:text="@string/landing_login_button"
                    android:textAllCaps="false"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    app:backgroundTint="@color/zamov"
                    app:cornerRadius="24dp"
                    app:rippleColor="@color/uklon_ripple" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:fontFamily="@font/medium"
            android:text="@string/landing_services_title"
            android:textColor="@color/uklon_on_bg"
            android:textSize="17sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:baselineAligned="false"
            android:orientation="horizontal"
            android:weightSum="3">

            <include
                android:id="@+id/actionOrder"
                layout="@layout/item_landing_action"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="6dp"
                android:layout_weight="1" />

            <include
                android:id="@+id/actionCalculation"
                layout="@layout/item_landing_action"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="6dp"
                android:layout_weight="1" />

            <include
                android:id="@+id/actionCity"
                layout="@layout/item_landing_action"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:baselineAligned="false"
            android:orientation="horizontal"
            android:weightSum="3">

            <include
                android:id="@+id/actionPayment"
                layout="@layout/item_landing_action"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="6dp"
                android:layout_weight="1" />

            <include
                android:id="@+id/actionLanguage"
                layout="@layout/item_landing_action"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="6dp"
                android:layout_weight="1" />

            <include
                android:id="@+id/actionOperator"
                layout="@layout/item_landing_action"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:baselineAligned="false"
            android:orientation="horizontal"
            android:weightSum="3">

            <include
                android:id="@+id/actionDriver"
                layout="@layout/item_landing_action"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="6dp"
                android:layout_weight="1" />

            <include
                android:id="@+id/actionExit"
                layout="@layout/item_landing_action"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="6dp"
                android:layout_weight="1" />

            <Space
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
