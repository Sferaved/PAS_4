<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="20dp"
    android:layout_marginEnd="20dp"
    android:background="@drawable/bg_dialog_rounded"
    android:orientation="vertical"
    android:paddingStart="22dp"
    android:paddingTop="24dp"
    android:paddingEnd="22dp"
    android:paddingBottom="18dp">

    <FrameLayout
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_gravity="center_horizontal"
        android:background="@drawable/bg_dialog_icon_circle_soft">

        <ImageView
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_gravity="center"
            android:contentDescription="@null"
            android:src="@drawable/ic_menu_slideshow"
            app:tint="@color/zamov" />
    </FrameLayout>

    <TextView
        android:id="@+id/langDialogTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:fontFamily="@font/medium"
        android:gravity="center"
        android:text="@string/landing_language_dialog_title"
        android:textColor="@color/uklon_on_surface"
        android:textSize="20sp" />

    <TextView
        android:id="@+id/langDialogSubtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:fontFamily="@font/regular"
        android:gravity="center"
        android:lineSpacingExtra="2dp"
        android:text="@string/landing_language_dialog_subtitle"
        android:textColor="@color/uklon_on_surface_secondary"
        android:textSize="14sp" />

    <include
        android:id="@+id/langOptionEn"
        layout="@layout/item_landing_language_option"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp" />

    <include
        android:id="@+id/langOptionRu"
        layout="@layout/item_landing_language_option"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp" />

    <include
        android:id="@+id/langOptionUk"
        layout="@layout/item_landing_language_option"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/langDialogBtnCancel"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_marginEnd="6dp"
            android:layout_weight="1"
            android:background="@drawable/bg_dialog_btn_cancel"
            android:clickable="true"
            android:focusable="true"
            android:fontFamily="@font/regular"
            android:gravity="center"
            android:text="@string/cancel"
            android:textColor="@color/uklon_on_surface"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/langDialogBtnSave"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:background="@drawable/bg_dialog_btn_primary"
            android:clickable="true"
            android:focusable="true"
            android:fontFamily="@font/medium"
            android:gravity="center"
            android:text="@string/save"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="15sp" />
    </LinearLayout>
</LinearLayout>
