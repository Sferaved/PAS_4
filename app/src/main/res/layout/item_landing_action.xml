<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_landing_action_tile"
    android:clickable="true"
    android:focusable="true"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:paddingStart="6dp"
    android:paddingTop="14dp"
    android:paddingEnd="6dp"
    android:paddingBottom="12dp">

    <ImageView
        android:id="@+id/ivLandingIcon"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:background="@drawable/bg_landing_icon_soft"
        android:clickable="false"
        android:contentDescription="@null"
        android:focusable="false"
        android:padding="11dp"
        android:scaleType="centerInside"
        android:src="@drawable/ic_shortcut_order"
        app:tint="@color/zamov" />

    <TextView
        android:id="@+id/tvLandingLabel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:clickable="false"
        android:focusable="false"
        android:fontFamily="@font/regular"
        android:gravity="center"
        android:lineSpacingExtra="1dp"
        android:maxLines="2"
        android:textColor="@color/uklon_on_surface"
        android:textSize="12sp" />
</LinearLayout>
